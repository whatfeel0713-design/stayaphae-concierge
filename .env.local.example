# 이 파일을 .env.local로 복사한 뒤 값을 채워 넣으세요. (gitignore됨)
# 메인 사이트(staysoom)와 같은 Supabase 프로젝트를 공유합니다 — anon key만 사용.

# --- Supabase (메인 사이트와 동일 프로젝트, 프로젝트 설정 > API에서 확인) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- 세션 쿠키 서명 비밀값 (guide_code 검증 후 발급하는 httpOnly JWT 서명용) ---
# 값 생성 예: openssl rand -hex 32
GUIDE_SESSION_SECRET=

# --- 사이트 ---
# 배포 URL. Vercel 프로젝트 연결 전: https://<프로젝트명>.vercel.app
# 도메인 연결 후: https://concierge.stayaphae.com
NEXT_PUBLIC_SITE_URL=
