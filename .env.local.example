# 이 파일을 .env.local로 복사한 뒤 값을 채워 넣으세요. (gitignore됨)
# 메인 사이트(staysoom)와 같은 Supabase 프로젝트를 공유합니다 — anon key만 사용.

# --- Supabase (메인 사이트와 동일 프로젝트, 프로젝트 설정 > API에서 확인) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- 세션 쿠키 서명 비밀값 (guide_code 검증 후 발급하는 httpOnly JWT 서명용) ---
# 값 생성 예: openssl rand -hex 32
GUIDE_SESSION_SECRET=

# --- AI 컨시어지 챗 (/chat, api/chat) ---
# console.anthropic.com 에서 발급. 서버에서만 사용 — 클라이언트에 노출되지 않음.
# 비어 있으면 /chat은 열리지만 응답은 503(설정 필요 안내)을 반환한다.
ANTHROPIC_API_KEY=

# --- 실시간 날씨 (기상청 단기예보 조회서비스, data.go.kr에서 신청) ---
# 비어 있으면 챗이 "날씨 연동이 아직 설정되지 않았다"고 솔직히 답한다.
KMA_SERVICE_KEY=
# 압해읍의 기상청 격자 좌표(nx, ny) — 기상청 "동네예보 격자 X,Y 조회" 페이지에서
# 신안군 압해읍 주소로 검색해 확인할 것. 하드코딩하지 않고 반드시 직접 확인 후 채울 것.
KMA_NX=
KMA_NY=

# --- 실시간 물때 (국립해양조사원 오픈API, khoa.go.kr에서 신청) ---
# ⚠️ 이 통합은 API 스펙을 실시간 검색으로 재확인하지 못한 채 구현됐다
# (src/lib/weather-tide.ts 상단 주석 참고) — 서비스키 발급 후 반드시
# 실제 응답을 콘솔 로그로 한 번 확인하고 필요하면 파싱 로직을 조정할 것.
KHOA_SERVICE_KEY=
# 압해도에서 가장 가까운 조위관측소 코드(예: 목포) — khoa.go.kr에서 확인.
KHOA_OBS_CODE=

# --- 사이트 ---
# 배포 URL. Vercel 프로젝트 연결 전: https://<프로젝트명>.vercel.app
# 도메인 연결 후: https://concierge.stayaphae.com
NEXT_PUBLIC_SITE_URL=
